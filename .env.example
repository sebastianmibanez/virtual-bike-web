# === Supabase ===
# Públicas (se exponen al cliente, está bien):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRETA — solo servidor. Omite RLS para crear/actualizar órdenes. NUNCA con prefijo NEXT_PUBLIC_:
SUPABASE_SERVICE_ROLE_KEY=

# === URL pública del sitio (para metadata, OG, sitemap y returnUrl de pago) ===
NEXT_PUBLIC_SITE_URL=https://virtual-bike.cl

# === Getnet / PlaceToPay (WebCheckout) — SECRETAS, solo servidor ===
# Credenciales del comercio. En Getnet Chile suele ser el endpoint PlaceToPay.
GETNET_LOGIN=
GETNET_SECRET_KEY=
# Producción: https://checkout.getnet.cl   |   Pruebas: el endpoint sandbox que entregue Getnet
GETNET_BASE_URL=https://checkout.getnet.cl
